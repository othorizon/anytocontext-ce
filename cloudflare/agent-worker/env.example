# =====================================================================
# anytocontext-agent-worker — local secrets template
# anytocontext-agent-worker —— 本地 secrets 模板
#
# Copy to `.dev.vars` for `wrangler dev`, or push to a deployed worker
# via `wrangler secret put <KEY> --env prod`.
# 复制为 `.dev.vars` 用于 `wrangler dev`；生产环境改用
# `wrangler secret put <KEY> --env prod` 推送。
#
# IMPORTANT: never commit your real `.dev.vars`.
# 注意：请勿把真实 `.dev.vars` 提交到仓库。
# =====================================================================

# Shared HMAC secret between the main app and the worker — must match
# `INTERNAL_API_SECRET` in the main app's `.env`.
# 与主应用 .env 中的 INTERNAL_API_SECRET 完全一致。
INTERNAL_API_SECRET=""

# R2 S3 credentials (used by sandbox.mountBucket to mount R2 from inside
# the container; not exposed as a worker binding).
# Sandbox 容器通过 S3 API 挂载 R2，所以需要单独的 S3 凭证。
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# -----------------------------------------------
# OpenAI-compatible chat model (single provider).
# 单一 OpenAI 兼容模型 provider。
# Works with any provider that speaks the OpenAI Chat Completions API:
# OpenAI / Azure OpenAI / DeepSeek / OpenRouter / Ollama / vLLM / ...
# 任何兼容 OpenAI Chat Completions 协议的服务都可以接：
# OpenAI / Azure OpenAI / DeepSeek / OpenRouter / Ollama / vLLM 等。
# -----------------------------------------------
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
