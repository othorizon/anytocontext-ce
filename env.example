# =====================================================================
# anytocontext (community edition) — environment template
# anytocontext 社区版 —— 环境变量模板
#
# Copy to `.env` for local dev, or set via your deploy platform.
# 复制为 `.env` 用于本地开发，或在部署平台上配置等价的密钥。
#
# IMPORTANT: never commit your real `.env`. Fill in real values only on
#            the machine that runs the app. `env.example` is tracked.
# 注意：请不要把真实 `.env` 提交到仓库；只在运行节点填入真实值。
#       `env.example` 本身会随仓库一起提交，作为字段说明用。
# =====================================================================


# -----------------------------------------------
# Postgres (e.g. Neon, Supabase, self-hosted PG)
# 应用用的 Postgres（可用 Neon / Supabase / 自建）
# -----------------------------------------------
# Runtime DSN — used by Prisma Client at request time.
# For Neon, prefer the *pooled* host (contains `-pooler`).
# 运行时连接串。Neon 优先用带 `-pooler` 的连接串。
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Direct (non-pooled) DSN — used by Prisma migrate / CLI.
# Neon poolers do not support DDL; this must be a direct host.
# 直连连接串，用于跑 migration。Neon 的 pooler 不支持 DDL。
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"


# -----------------------------------------------
# Clerk (authentication)
# Clerk（身份认证）
# Create an app at https://dashboard.clerk.com and paste keys here.
# 在 https://dashboard.clerk.com 新建应用后填入即可。
# -----------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""


# -----------------------------------------------
# Cloudflare R2 (S3-compatible storage)
# Cloudflare R2 对象存储（S3 兼容）
# Used by the Next.js app to read build logs / clean up project prefixes.
# 主应用只用读路径：代理构建日志，删项目时清前缀。
# -----------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Either R2_ENDPOINT or R2_ACCOUNT_ID is required.
# 二选一：直接给 R2_ENDPOINT，或者给 R2_ACCOUNT_ID 自动推断。
R2_ENDPOINT=""


# -----------------------------------------------
# Agent Worker (Cloudflare Workers + Durable Objects + Containers)
# Agent Worker（CF Workers + Durable Objects + Containers）
# Local dev: run `pnpm wrangler dev` inside cloudflare/agent-worker/.
# 本地开发：在 cloudflare/agent-worker 下跑 `pnpm wrangler dev`。
# -----------------------------------------------
# Where the main Next.js app can reach the worker (HTTP).
# 主应用调用 worker 的地址。
SANDBOX_WORKER_URL="http://localhost:8790"
# Shared secret between the main app and the worker — must match
# `INTERNAL_API_SECRET` in cloudflare/agent-worker/.dev.vars (local)
# or `wrangler secret put INTERNAL_API_SECRET` (deployed).
# 主应用和 worker 之间的握手 secret，两端必须一致。
INTERNAL_API_SECRET=""


# -----------------------------------------------
# Credential encryption (SSH keys, etc.) master key
# 凭证加密主密钥（用于 SSH key 等）
# Generate with:  `openssl rand -base64 32`
# 32 bytes, base64-encoded. Losing this means all stored credentials
# become unreadable; rotate carefully.
# 32 字节 base64 编码。一旦丢失，已存的凭证将无法解密；轮换需谨慎。
# -----------------------------------------------
CREDENTIAL_MASTER_KEY=""
